# Token-budget mode (under-development flag): replaces lossy remote-compaction
# summaries with checkpoint-file + summary-free reset via the new_context tool.
# Works with the precompaction hooks (hooks.json) and the AGENTS.md
# "Context resets" rules. Remove this table to revert to normal compaction.
[features.token_budget]
enabled = true
reminder_threshold_tokens = 45000
reminder_message_template = 'Only {n_remaining} tokens remain before a summary-free context reset. Finish the current atomic action, then read .codex-precompaction/FORMAT.md in the workspace and write a checkpoint to .codex-precompaction/PRECOMPACTION_<your session marker>_<n>.md following it exactly (TASK — the current assignment with the user request quoted verbatim, its exact meaning, the nearest wrong reading ruled out, and the reason behind it; INVARIANTS — standing project rules copied forward verbatim from the previous checkpoint, never re-summarized; PLAN; STATUS with verification; USER NOTES; DECISIONS incl. rejections; INCIDENTS dated; POINTERS; IN-FLIGHT; NEXT; WORKING SET; NOW, incl. live user signals and your own pending intent — a user stop REMAINS IN FORCE across the reset, and if you were about to yield, respond or ask, that is still your next move after it — outcomes and current state only, no narrative, under ~150 lines; if FORMAT.md is missing use this section list, and if you lack a session marker use the current date-time). Then call the new_context tool and resume from the checkpoint.'
