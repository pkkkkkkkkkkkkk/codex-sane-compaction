# Token-budget mode (under-development flag): replaces lossy remote-compaction
# summaries with checkpoint-file + summary-free reset via the new_context tool.
# Works with the precompaction hooks (hooks.json) and the AGENTS.md
# "Context resets" rules. Remove this table to revert to normal compaction.
[features.token_budget]
enabled = true
reminder_threshold_tokens = 45000
reminder_message_template = 'Only {n_remaining} tokens remain before a summary-free context reset. Finish the current atomic action, then read .codex-precompaction/FORMAT.md in the workspace and write a checkpoint to .codex-precompaction/PRECOMPACTION_<your session marker>_<n>.md following it exactly (PLAN; STATUS with verification; USER NOTES; DECISIONS incl. rejections; INCIDENTS dated; POINTERS; IN-FLIGHT; NEXT; WORKING SET — outcomes and current state only, no narrative, under ~150 lines; if FORMAT.md is missing use this section list, and if you lack a session marker use the current date-time). Then call the new_context tool and resume from the checkpoint.'
